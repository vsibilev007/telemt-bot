# ─── Обязательные ─────────────────────────────────────────────────────────────

# Telegram Bot Token (от @BotFather)
BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff1234567890

# Список разрешённых Telegram user_id (через запятую)
# Узнать свой ID: @userinfobot или @getmyid_bot
ALLOWED_USERS=123456789,987654321


# ─── Серверы Telemt ───────────────────────────────────────────────────────────

# Один сервер:
SERVER_URL=http://127.0.0.1:9091
SERVER_NAME=My Telemt
SERVER_AUTH=my-secret-auth-header

# Несколько серверов (нумерация с 1):
# SERVER_1_URL=http://IP:9091
# SERVER_1_NAME=Server 1
# SERVER_1_AUTH=secret1
#
# SERVER_2_URL=http://IP:9091
# SERVER_2_NAME=Server 2
# SERVER_2_AUTH=secret2


# ─── Кластер (HA) ─────────────────────────────────────────────────────────────

# Серверы с одинаковым GROUP объединяются в кластер.
# Write-операции выполняются параллельно на всех узлах группы.
# Read — с первого доступного.
#
# Пример:
# SERVER_1_URL=http://IP:9091
# SERVER_1_NAME=HA_A
# SERVER_1_GROUP=cluster_ha
#
# SERVER_2_URL=http://IP:9091
# SERVER_2_NAME=HA_B
# SERVER_2_GROUP=cluster_ha


# ─── Пороги алертов ───────────────────────────────────────────────────────────

# ALERT_CONN_SPIKE_PCT=50        # всплеск соединений, %
# ALERT_CONN_SPIKE_MIN_BASE=100  # мин. база соединений для срабатывания
# ALERT_WRITERS_LOW_PCT=80       # порог coverage ME Writers, %
# ALERT_HS_TIMEOUT_SPIKE=50      # handshake timeout, +N за 2 мин
# ALERT_BAD_CLIENT_SPIKE=100     # плохих TLS клиентов, +N за 2 мин
# ALERT_QUOTA_PCT=80             # алерт при использовании N% квоты клиента


# ─── Логирование ──────────────────────────────────────────────────────────────

# LOG_LEVEL=INFO          # DEBUG / INFO / WARNING / ERROR
# LOG_FILE=telemt_bot.log # путь к файлу (пусто = только stdout)
# LOG_MAX_MB=10           # макс. размер файла до ротации
# LOG_BACKUPS=3           # кол-во резервных файлов
# NO_COLOR=1              # отключить ANSI-цвета (для non-tty окружений)


# ─── Часовой пояс ─────────────────────────────────────────────────────────────

# TZ=Europe/Moscow        # MSK (UTC+3)
# TZ=Asia/Yekaterinburg  # YEKT (UTC+5)
# TZ=Asia/Novosibirsk    # NOVT (UTC+7)
# TZ=Europe/London       # BST/GMT
# TZ=UTC                 # без смещения
# Полный список: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones


# ─── Агенты проверки прокси ───────────────────────────────────────────────────

# Каждый агент — отдельный сервер с proxy_agent.py
# FLAG — эмодзи флага. Если не задан — определяется по IP через GeoIP автоматически
#
# AGENT_1_URL=http://IP:8765
# AGENT_1_NAME=RU
# AGENT_1_TOKEN=your-secret-token
# AGENT_1_FLAG=🇷🇺
#
# AGENT_2_URL=http://IP:8765
# AGENT_2_NAME=Asia
# AGENT_2_TOKEN=your-secret-token
# AGENT_2_FLAG=🇯🇵
#
# Обратная совместимость (один агент):
# PROXY_AGENT_URL=http://IP:8765
# PROXY_AGENT_TOKEN=your-secret-token


# ─── Прокси для Telegram API ──────────────────────────────────────────────────

# Если бот запущен в России и Telegram API заблокирован,
# укажите прокси для подключения к Telegram:
# TELEGRAM_PROXY_URL=socks5://user:password@host:port
# TELEGRAM_PROXY_URL=http://host:port
# Поддержка: SOCKS5, SOCKS4, HTTP


# ─── Пути ─────────────────────────────────────────────────────────────────────

# Путь к файлу БД (по умолчанию рядом со скриптом)
# TELEMT_BOT_DB_PATH=/var/lib/telemt-bot/bot.db

# Путь к telemt.toml для бэкапа (по умолчанию /etc/telemt/telemt.toml)
# TELEMT_CONFIG_PATH=/etc/telemt/telemt.toml


# ─── Lite режим ───────────────────────────────────────────────────────────────

# Отключает: графики, scheduler, алерты, отчёт по трафику,
# истекающие, безопасность, upstreams, DC/Writers, проверку прокси
# Оставляет: состояние сервера, клиенты, создание, runtime, бэкап
# LITE_MODE=true
